{
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "bestamericanautotransport.com" }],
      "destination": "https://www.bestamericanautotransport.com/:path*",
      "permanent": true
    },
    { "source": "/routes/:slug/", "destination": "/:slug/", "permanent": true },
    { "source": "/services/open-transport", "destination": "/services/open-auto-transport", "permanent": true },
    { "source": "/services/enclosed-transport", "destination": "/services/enclosed-auto-transport", "permanent": true },
    { "source": "/services/luxury-exotic-car-shipping-services", "destination": "/services/luxury-car-shipping", "permanent": true },
    { "source": "/services/door-to-door-car-transport", "destination": "/services/door-to-door-car-shipping", "permanent": true }
  ],
  "rewrites": [
    { "source": "/about/", "destination": "/about.html" },
    { "source": "/faq/", "destination": "/faq.html" },
    { "source": "/reviews/", "destination": "/reviews.html" },
    { "source": "/contact/", "destination": "/contact.html" },
    { "source": "/locations/", "destination": "/locations.html" },
    { "source": "/privacy/", "destination": "/privacy.html" },
    { "source": "/terms/", "destination": "/terms.html" },
    { "source": "/why-best-american/", "destination": "/why-best-american.html" },
    { "source": "/blog/:slug/", "destination": "/blog/:slug.html" },
    { "source": "/:slug([a-z-]+-car-shipping)/", "destination": "/routes/:slug" }
  ]
}
